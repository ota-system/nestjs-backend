{
	"name": "nest_todo",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"build": "nest build",
		"format": "biome format --write .",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "biome check .",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./test/jest-e2e.json",
		"prepare": "husky",
		"typecheck": "tsc --noEmit",
		"typeorm": "ts-node ./node_modules/typeorm/cli",
		"migration:generate": "npm run build && npm run typeorm -- -d src/database/data-source.ts migration:generate",
		"migration:run": "npm run build && npm run typeorm -- -d src/database/data-source.ts migration:run",
		"migration:revert": "npm run build && npm run typeorm -- -d src/database/data-source.ts migration:revert"
	},
	"lint-staged": {
		"**/*.{ts,js,tsx}": "biome check --write --no-errors-on-unmatched",
		"**/*.{json,css,html,md}": "biome format --write --no-errors-on-unmatched"
	},
	"dependencies": {
		"@liaoliaots/nestjs-redis": "^10.0.0",
		"@nestjs-modules/mailer": "^2.3.4",
		"@nestjs/axios": "^4.0.1",
		"@nestjs/bullmq": "^11.0.4",
		"@nestjs/common": "^11.0.1",
		"@nestjs/config": "^4.0.4",
		"@nestjs/core": "^11.0.1",
		"@nestjs/jwt": "^11.0.2",
		"@nestjs/mapped-types": "*",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-express": "^11.0.1",
		"@nestjs/swagger": "^11.2.7",
		"@nestjs/terminus": "^11.1.1",
		"@nestjs/typeorm": "^11.0.1",
		"@types/passport-google-oauth20": "^2.0.17",
		"axios": "^1.15.0",
		"bcryptjs": "^3.0.3",
		"bullmq": "^4.18.3",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.15.1",
		"crypto": "^1.0.1",
		"handlebars": "^4.7.9",
		"ioredis": "^5.10.1",
		"jwt-decode": "^4.0.0",
		"nestjs-i18n": "^10.6.0",
		"nodemailer": "^8.0.5",
		"passport": "^0.7.0",
		"passport-google-oauth20": "^2.0.0",
		"passport-jwt": "^4.0.1",
		"pg": "^8.20.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"typeorm": "^0.3.28"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@eslint/eslintrc": "^3.2.0",
		"@eslint/js": "^9.18.0",
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.0.1",
		"@types/bcryptjs": "^2.4.6",
		"@types/express": "^5.0.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^24.12.2",
		"@types/nodemailer": "^8.0.0",
		"@types/supertest": "^7.0.0",
		"globals": "^17.0.0",
		"husky": "^9.1.7",
		"jest": "^30.0.0",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.7.3",
		"typescript-eslint": "^8.20.0",
		"validate-branch-name": "^1.3.2"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}
